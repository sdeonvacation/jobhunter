{
  "name": "jobhunter-mcp",
  "version": "1.1.0",
  "description": "MCP server for JobHunter - query and manage job postings from any AI assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jobhunter-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "keywords.yaml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sdeonvacation/jobhunter"
  },
  "keywords": ["mcp", "job-search", "career", "ai-assistant"],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
